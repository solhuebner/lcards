# Test CB-LCARS Configuration for Migration Testing

# Resources
resources:
  - url: /hacsfiles/cb-lcars/cb-lcars.js
    type: module

views:
  - title: Bridge
    cards:
      # Test button card
      - type: custom:cb-lcars-button-card
        entity: light.bridge
        cblcars_card_type: cb-lcars-button-lozenge
        name: "BRIDGE"
        show_state: true
        tap_action:
          action: toggle

      # Test elbow card
      - type: custom:cb-lcars-elbow-card
        cblcars_card_type: cb-lcars-elbow-left
        size: large
        color: orange

      # Test MSD card
      - type: custom:cb-lcars-msd-card
        cb-lcars-msd:
          version: 1
          base_svg:
            source: "builtin:enterprise-d"
          overlays:
            - id: bridge_status
              type: status_grid
              position: [200, 100]
              entities:
                - light.bridge_main
                - sensor.bridge_occupancy

      # Test multimeter
      - type: custom:cb-lcars-multimeter-card
        entity: sensor.warp_core_temperature
        cblcars_card_type: cb-lcars-multimeter-radial
        show_name: true

  - title: Engineering
    cards:
      # Grid with multiple CB-LCARS cards
      - type: grid
        columns: 3
        cards:
          - type: custom:cb-lcars-button-card
            cblcars_card_type: cb-lcars-button-picard
            entity: switch.warp_core
          - type: custom:cb-lcars-label-card
            cblcars_card_type: cb-lcars-label-header
            text: "WARP CORE"
          - type: custom:cb-lcars-elbow-card
            cblcars_card_type: cb-lcars-elbow-top-right